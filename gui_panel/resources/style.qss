QWidget { background-color: #1e1e1e; color: #ccc; }
QListWidget { background-color: #2d2d2d; border: none; }
QTextEdit { background-color: #252525; font-family: monospace; }
QPushButton { background-color: #3a3a3a; border: 1px solid #555; padding: 5px; }
QPushButton:hover { background-color: #4a4a4a; }